{
  "name": "janet",
  "version": "0.1.2",
  "description": "JaneT - A powerful cross-platform terminal with file explorer, SSH, and git tree",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:main": "npx esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --external:electron --external:node-pty --external:ssh2 --external:ssh2-sftp-client --external:simple-git",
    "build:preload": "npx esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron",
    "build:renderer": "npx vite build --config vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npx electron dist/main/index.js",
    "dist": "npm run build && npx electron-builder",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:linux": "npm run build && npx electron-builder --linux",
    "publish": "npm run build && npx electron-builder --publish always",
    "publish:win": "npm run build && npx electron-builder --win --publish always",
    "publish:mac": "npm run build && npx electron-builder --mac --publish always",
    "publish:linux": "npm run build && npx electron-builder --linux --publish always"
  },
  "build": {
    "appId": "com.sjorm.janet",
    "productName": "JaneT",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/renderer/**/*.map"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/ssh2/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-Setup-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JaneT",
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "unicode": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-win-x64.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-linux-x64.${ext}",
      "maintainer": "sjorm <sjorm@users.noreply.github.com>",
      "category": "TerminalEmulator",
      "synopsis": "A powerful cross-platform terminal emulator",
      "description": "JaneT - A powerful cross-platform terminal with file explorer, SSH, and git tree",
      "executableName": "janet"
    },
    "publish": {
      "provider": "github",
      "owner": "Sjormz",
      "repo": "JaneT",
      "releaseType": "release"
    }
  },
  "keywords": [
    "terminal",
    "ssh",
    "file-explorer",
    "git"
  ],
  "author": "sjorm <sjorm@users.noreply.github.com>",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.22.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.36.0",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
