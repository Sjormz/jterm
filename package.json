{
  "name": "jterm",
  "version": "0.1.0",
  "description": "JTerm - A powerful cross-platform terminal with file explorer, SSH, and git tree",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build:main": "npx esbuild src/main/index.ts --bundle --platform=node --outfile=dist/main/index.js --external:electron --external:node-pty --external:ssh2 --external:ssh2-sftp-client --external:simple-git",
    "build:preload": "npx esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron",
    "build:renderer": "npx vite build --config vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npx electron dist/main/index.js",
    "dist": "npx electron-builder"
  },
  "build": {
    "appId": "com.pckpr.jterm",
    "productName": "JTerm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!dist/renderer/**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  },
  "keywords": [
    "terminal",
    "ssh",
    "file-explorer",
    "git"
  ],
  "author": "pckpr",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^1.22.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.36.0",
    "ssh2": "^1.17.0",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@types/ssh2-sftp-client": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
